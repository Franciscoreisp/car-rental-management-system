<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Stand</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="@Url.Content("~/Content/Site.css")" />
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
        <div class="container">
            @if (Session["utilizador"] != null)
            {
                <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                    <img src="@Url.Content("~/Fotos/logo.png")"
                         alt="Stand de Automóveis"
                         style="height: 36px; width: auto;" />
                </a>
            }
            else
            {
                <span class="navbar-brand" style="cursor: default;">
                    <img src="@Url.Content("~/Fotos/logo.png")"
                         alt="Stand de Automóveis"
                         style="height: 36px; width: auto;" />
                </span>
            }

            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                @if (Session["utilizador"] == null)
                {
                    <ul class="navbar-nav ms-auto">
                        @if (ViewBag.PaginaAtual != "Login")
                        {
                            <li class="nav-item">@Html.ActionLink("Login", "Login", "Login", new { area = "" }, new { @class = "nav-link" })</li>
                        }
                        @if (ViewBag.PaginaAtual != "Register")
                        {
                            <li class="nav-item">@Html.ActionLink("Criar Conta", "Register", "Login", new { area = "" }, new { @class = "nav-link" })</li>
                        }
                    </ul>
                }
                else
                {
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">@Html.ActionLink("Clientes", "Clientes", "Stand", new { area = "" }, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Carros", "Carros", "Stand", new { area = "" }, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Alugueres", "Alugueres", "Stand", new { area = "" }, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Email", "EnviarEmail", "Email", new { area = "" }, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Newsletter", "Newsletter", "Newsletter", new { area = "" }, new { @class = "nav-link" })</li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            @Html.ActionLink("Bem-vindo, " + Session["utilizador"], "BemVindo", "Home",
                                new { area = "" },
                                new { @class = "nav-link text-warning fw-semibold" })
                        </li>
                        <li class="nav-item">@Html.ActionLink("Logout", "Logout", "Login", new { area = "" }, new { @class = "nav-link" })</li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - Stand de Automóveis</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>