@model Trabalho.Models.aluguere

@{
    ViewBag.Title = "CreateAluguer";
}

<h2>Criar um Aluguer</h2>

@using (Html.BeginForm("CreateAluguer", "Stand", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.LabelFor(model => model.idcli, "Cliente", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.idcli, ViewBag.clientes as SelectList, new { @class = "form-select" })
                @Html.ValidationMessageFor(model => model.idcli, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.idcar, "Carro", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.idcar, ViewBag.carros as SelectList, new { @class = "form-select" })
                @Html.ValidationMessageFor(model => model.idcar, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.inicio, "Data de Início", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.inicio, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date" })
                @Html.ValidationMessageFor(model => model.inicio, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.fim, "Data de Fim", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.fim, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date" })
                @Html.ValidationMessageFor(model => model.fim, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Criar" />
            </div>
        </div>
    </div>
}

<div>
    <a href="@Url.Action("Alugueres", "Stand")" class="btn-link-custom">&#8592; Voltar à lista</a>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}