@model Trabalho.Models.cliente

@{
    ViewBag.Title = "EditCliente";
}

<h2>Editar o Cliente</h2>

@using (Html.BeginForm("EditCliente", "Stand", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <hr />

    <div class="form-horizontal" style="max-width:520px;">
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.idcli)

        <div class="form-group">
            @Html.LabelFor(model => model.nome, "Nome", htmlAttributes: new { @class = "control-label" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.nome, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.nome, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.datanasc, "Data de Nascimento", htmlAttributes: new { @class = "control-label" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.datanasc, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date" })
                @Html.ValidationMessageFor(model => model.datanasc, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.categoria, "Categoria", htmlAttributes: new { @class = "control-label" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.categoria, ViewBag.categorias as SelectList, new { @class = "form-select" })
                @Html.ValidationMessageFor(model => model.categoria, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.tutor, "Tutor", htmlAttributes: new { @class = "control-label" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.tutor, ViewBag.tutores as SelectList, "-- Sem Tutor --", new { @class = "form-select" })
                @Html.ValidationMessageFor(model => model.tutor, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.photopath, "Foto", htmlAttributes: new { @class = "control-label" })
            <div class="col-md-10">
                @if (Model.photopath != null)
                {
                    <img id="previewFoto" src="@Url.Content($"~/Fotos/{Model.photopath}")"
                         style="height:80px; margin-bottom:8px; display:block; border-radius:6px;" />
                }
                else
                {
                    <img id="previewFoto" src="@Url.Content("~/Fotos/nophoto.png")"
                         style="height:80px; margin-bottom:8px; display:block; border-radius:6px;" />
                }
                <input type="file" name="fich" id="fich" accept="image/*" class="form-control" />
                <small style="color:#999;">Deixa vazio para manter a foto atual</small>
                @Html.ValidationMessageFor(model => model.photopath, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-10">
                <input type="submit" value="Guardar" style="margin-top: 8px;" />
            </div>
        </div>
    </div>
}

<div style="margin-top:12px;">
    <a href="@Url.Action("Clientes", "Stand")" class="btn-link-custom">&#8592; Voltar à lista</a>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        document.getElementById('fich').addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewFoto').src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}